# 복사해서 사용: cp .env.example .env  (.env는 git에 커밋하지 않음)

# --- 서버 docker-compose용 ---
# 앱 nginx가 호스트에 노출되는 포트 (엣지 nginx 443/80과 충돌 금지)
APP_PORT=3333

POSTGRES_USER=processmap
POSTGRES_PASSWORD=change-me
POSTGRES_DB=processmap

# --- 로컬 네이티브 실행용 (Docker 없음) ---
# backend DB — 기본은 무설정 sqlite 파일. 로컬 Postgres를 쓰면 아래 줄로 교체:
#   DATABASE_URL=postgresql+asyncpg://processmap:change-me@localhost:5432/processmap
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# frontend dev 서버가 /api 를 프록시할 backend 주소 (next.config.ts rewrites)
BACKEND_URL=http://localhost:8000

# 버전 체크아웃 잠금의 무활동 자동 해제 시간(분) — spec §7 Phase C
CHECKOUT_TTL_MINUTES=30

# --- Keycloak 인증 (docs/spec.md §4) ---
# 서버 compose는 기본 활성(AUTH_ENABLED=true). 로컬 네이티브는 Keycloak 접근 불가 →
# backend는 .env에 AUTH_ENABLED 미설정(기본 false), frontend는 NEXT_PUBLIC_AUTH_ENABLED 미설정으로 우회.
AUTH_ENABLED=true
# dev-only: AUTH OFF에서도 X-Dev-User의 실제 권한을 계산해 로컬 역할 검증.
# 기본 false = 전원 sysadmin(현행 동작). true로 설정하면 BPM_SYSADMINS 외엔 실제 역할 적용.
# 서버(AUTH_ENABLED=true)에선 무의미 — 추가 불필요.
#DEV_ENFORCE_PERMISSIONS=false
KEYCLOAK_ISSUER=http://182.199.63.71:8080/realms/ai-portal
# 토큰 aud 검증값 (비우면 생략)
KEYCLOAK_AUDIENCE=
# Keycloak에 등록한 public(PKCE) 클라이언트 ID
KEYCLOAK_CLIENT_ID=bpm-frontend

# frontend 빌드용 (compose가 build args로 주입 — 로컬 dev에선 미설정 시 우회)
# NEXT_PUBLIC_AUTH_ENABLED=true
# NEXT_PUBLIC_KEYCLOAK_ISSUER=http://182.199.63.71:8080/realms/ai-portal
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=bpm-frontend

# 편집용 반응형 매뉴얼 사이트 주소 — 설정 시 에디터 툴바 우측에 이동 버튼 노출, 비우면 숨김
# 예: MANUAL_URL=https://manual.example.com
MANUAL_URL=

# 온프레미스 AI (OpenAI 호환 GPU 서버). 로컬은 비활성, 서버 compose에서만 설정.
# 로컬 테스트는 공개 OpenAI 호환 API로도 가능 (OpenAI/Groq 등) — 값만 교체. 예:
#   AI_BASE_URL=https://api.openai.com/v1  AI_MODEL=gpt-4o-mini
#   (Groq: AI_BASE_URL=https://api.groq.com/openai/v1)
# 주의: 이 루트 .env는 docker-compose용. 로컬 네이티브는 backend/.env(또는 shell export)가
#   로드됨 — docs/ai-connectivity-test.md 참고. AI_API_TOKEN은 시크릿, 절대 커밋 금지.
AI_ENABLED=false
AI_BASE_URL=
AI_API_TOKEN=
AI_MODEL=
AI_TIMEOUT_SECONDS=60

# === 사내 AD(LDAP) 동기화 (design 2026-06-16) ===
# 비우면 동기화 비활성(로컬 개발). 시크릿(LDAP_BIND_CREDENTIALS)은 절대 커밋 금지.
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_CREDENTIALS=
LDAP_USER_SEARCH_BASE=
LDAP_START_TLS=false
# 전체 enumerate 필터 — 비우면 기본 (&(objectCategory=person)(objectClass=user)(sAMAccountName=*))
LDAP_USER_FILTER=
# admin role loginId 콤마 구분 — require_admin용(디렉터리/조직 관리). 아래 sysadmin과 별개.
# 예: hong.gildong,kim.cheolsu
SYSTEM_ADMIN_LOGIN_IDS=
# BPM 시스템 관리자(sysadmin) loginId 콤마 구분 — 세팅의 관리자 섹션·전맵 접근·승인자 관리 권한.
#  · 서버(AUTH_ENABLED=true): 실제 Keycloak 사용자명을 넣어야 그 사람이 sysadmin. 비우면 아무도 sysadmin 아님.
#  · 로컬 네이티브(AUTH OFF + DEV_ENFORCE_PERMISSIONS=true)는 이 루트 .env가 아니라 backend/.env에
#    설정 — 종합 시드의 sysadmin은 admin.sys. 예: BPM_SYSADMINS=admin.sys
BPM_SYSADMINS=
